{
  "name": "lego-story-book",
  "version": "1.0.0",
  "description": "LEGO Story Book System - Interactive story creation for children",
  "scripts": {
    "dev": "wrangler pages dev . --compatibility-date=2024-01-01",
    "deploy": "wrangler pages deploy .",
    "db:init": "wrangler d1 execute lego-story-db --file=./schema.sql",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "playwright test"
  },
  "dependencies": {},
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20231218.0",
    "jest": "^29.7.0",
    "jest-environment-miniflare": "^2.14.2",
    "@playwright/test": "^1.40.1",
    "wrangler": "^3.22.0"
  },
  "jest": {
    "testEnvironment": "miniflare",
    "testMatch": ["**/*.test.js"],
    "setupFilesAfterEnv": ["./tests/setup.js"]
  }
}
